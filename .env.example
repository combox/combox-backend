APP_ENV=local
HTTP_ADDRESS=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_SHUTDOWN_TIMEOUT=15s
READY_TIMEOUT=2s
DEFAULT_LOCALE=en
STRINGS_PATH=strings
AUTH_ACCESS_SECRET=replace_with_access_secret_min_32_chars
AUTH_REFRESH_SECRET=replace_with_refresh_secret_min_32_chars
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=720h
BOT_TOKEN_PEPPER=replace_with_bot_token_pepper_min_32_chars

POSTGRES_DSN=postgres://chat:password@127.0.0.1:5432/chat?sslmode=disable
VALKEY_ADDR=127.0.0.1:6379
VALKEY_PASSWORD=
VALKEY_DB=0

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=chat-media
MINIO_API_INTERNAL=minio:9000
MINIO_SECURE=false
MINIO_REGION=us-east-1

MIGRATIONS_ENABLED=true
MIGRATIONS_PATH=migrations
POSTGRES_DB=chat

POSTGRES_USER=chat

POSTGRES_PASSWORD=password
